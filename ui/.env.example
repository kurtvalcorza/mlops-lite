# Operator console (BFF) configuration. Real values come from the repo .env at launch (run.sh
# sources it); this file documents what the BFF reads. NEVER commit real keys.

# Where the BFF reaches the gateway. localhost works from WSL (bidirectional forwarding) — no IP
# injection needed for UI→gateway (unlike the Docker gateway→native-daemon hop).
GATEWAY_URL=http://localhost:8080

# The gateway API key, server-side ONLY. run.sh derives this from GATEWAY_API_KEYS in the repo .env
# (first key). It is injected as X-API-Key by the BFF and never reaches the browser (FR-024).
GATEWAY_API_KEY=

# UI bind port (always 127.0.0.1, set in package.json/run.sh).
UI_PORT=3000
