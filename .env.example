# MLOps-Lite — environment template. Copy to .env, or run scripts/gen_secrets (PS1/SH) to
# generate one with random secrets. Secrets below are PLACEHOLDERS, not usable values (FR-017):
# bring-up fails fast if a required secret (MinIO/Postgres/Grafana credential) is unset.
# The real .env is git-ignored and must never be committed.

# Postgres (MLflow backend + gateway metadata)
POSTGRES_USER=mlops
POSTGRES_PASSWORD=__CHANGE_ME__          # required secret — no default in docker-compose.yml
POSTGRES_DB=mlflow
POSTGRES_PORT=55432

# MinIO (S3-compatible artifact + dataset storage) — no shipped minioadmin/minioadmin
MINIO_ROOT_USER=__CHANGE_ME__            # required secret
MINIO_ROOT_PASSWORD=__CHANGE_ME__        # required secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# MLflow tracking + registry
MLFLOW_PORT=5500

# Gateway (FastAPI) + API-key auth (US1, FR-016)
GATEWAY_PORT=8080
# Comma-separated API keys. Empty => gateway runs OPEN (logs a warning). Set one (e.g. mll_...)
# to require the 'X-API-Key' header on /infer, /models, /datasets, /runs, /monitor, /vision.
GATEWAY_API_KEYS=__CHANGE_ME__

# Observability
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=__CHANGE_ME__           # required secret — no shipped admin/admin
