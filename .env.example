# MLOps-Lite — environment template. Copy to .env, or run scripts/gen_secrets (PS1/SH) to
# generate one with random secrets. Secrets below are PLACEHOLDERS, not usable values (FR-017):
# bring-up fails fast if a required secret (MinIO/Postgres/Grafana credential) is unset.
# The real .env is git-ignored and must never be committed.

# Network exposure (005 US1, FR-041). All published Compose ports bind to this host interface.
# Default 127.0.0.1 = loopback-only (no LAN exposure). Set 0.0.0.0 ONLY for intentional LAN
# exposure — that re-exposes MinIO/MLflow/Grafana/Prometheus to anyone routable to this host.
BIND_ADDR=127.0.0.1

# Postgres (MLflow backend + gateway metadata)
POSTGRES_USER=mlops
POSTGRES_PASSWORD=__CHANGE_ME__          # required secret — no default in docker-compose.yml
POSTGRES_DB=mlflow
POSTGRES_PORT=55432

# MinIO (S3-compatible artifact + dataset storage) — no shipped minioadmin/minioadmin
MINIO_ROOT_USER=__CHANGE_ME__            # required secret
MINIO_ROOT_PASSWORD=__CHANGE_ME__        # required secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# MLflow tracking + registry
MLFLOW_PORT=5500

# Gateway (FastAPI) + API-key auth (US1, FR-016; fail-closed default, 005 US2, FR-042)
GATEWAY_PORT=8080
# Comma-separated API keys. Set one (e.g. mll_...) to require the 'X-API-Key' header on
# /infer, /models, /datasets, /runs, /monitor, /vision.
# Leave BLANK by default => fail-closed: the gateway still boots (/healthz, /metrics stay up) but
# protected lifecycle routes return 401 until a key is set — UNLESS GATEWAY_ALLOW_OPEN is truthy.
# (Do NOT leave a placeholder here — a literal value becomes a usable key. Run scripts/gen_secrets.)
GATEWAY_API_KEYS=
# Dev escape hatch (005 US2, FR-042). Truthy (1/true/yes) => run OPEN with no key and log a
# prominent warning. Leave empty in any non-throwaway setup. Never combine with BIND_ADDR=0.0.0.0.
GATEWAY_ALLOW_OPEN=

# Observability
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=__CHANGE_ME__           # required secret — no shipped admin/admin

# Inference tracing (006). Per-request MLflow traces of /infer + /infer/stream, reusing the existing
# MLflow server (MLFLOW_TRACKING_URI). Fire-and-forget + fail-open: never blocks or breaks inference.
MLFLOW_TRACING_ENABLED=1                  # 0/false disables tracing entirely (no per-request overhead)
MLFLOW_TRACE_CAPTURE_IO=1                 # 0/false keeps timing/metadata but omits prompt/output bodies
MLFLOW_TRACING_EXPERIMENT=mlops-lite-inference   # experiment traces land in (separate from training runs)
# Fast-fail backstop for the off-path export worker (defaults applied in app/tracing.py if unset):
# MLFLOW_HTTP_REQUEST_MAX_RETRIES=0
# MLFLOW_HTTP_REQUEST_TIMEOUT=5
