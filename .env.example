# MLOps-Lite — environment template. Copy to .env, or run scripts/gen_secrets (PS1/SH) to
# generate one with random secrets. Secrets below are PLACEHOLDERS, not usable values (FR-017):
# bring-up fails fast if a required secret (MinIO/Postgres/Grafana credential) is unset.
# The real .env is git-ignored and must never be committed.

# Network exposure (005 US1, FR-041). All published Compose ports bind to this host interface.
# Default 127.0.0.1 = loopback-only (no LAN exposure). Set 0.0.0.0 ONLY for intentional LAN
# exposure — that re-exposes MinIO/MLflow/Grafana/Prometheus to anyone routable to this host.
BIND_ADDR=127.0.0.1

# Postgres (MLflow backend + gateway metadata)
POSTGRES_USER=mlops
POSTGRES_PASSWORD=__CHANGE_ME__          # required secret — no default in docker-compose.yml
POSTGRES_DB=mlflow
POSTGRES_PORT=55432

# MinIO (S3-compatible artifact + dataset storage) — no shipped minioadmin/minioadmin
MINIO_ROOT_USER=__CHANGE_ME__            # required secret
MINIO_ROOT_PASSWORD=__CHANGE_ME__        # required secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# MLflow tracking + registry
MLFLOW_PORT=5500
# MLflow 3.x rejects requests whose Host header isn't allowlisted (DNS-rebinding guard). The default
# below covers the in-container healthcheck + the gateway + loopback clients on MLFLOW_PORT. If you set
# BIND_ADDR=0.0.0.0 for intentional LAN exposure, set this to the FULL list INCLUDING this host's LAN
# IP/hostname (e.g. "mlflow:5000,localhost:5000,127.0.0.1:5000,localhost:5500,127.0.0.1:5500,192.168.1.50:5500")
# or LAN callers get 403s. Leave unset for the loopback-only default.
# MLFLOW_ALLOWED_HOSTS=

# Gateway (FastAPI) + API-key auth (US1, FR-016; fail-closed default, 005 US2, FR-042)
GATEWAY_PORT=8080
# Comma-separated API keys. Set one (e.g. mll_...) to require the 'X-API-Key' header on
# /infer, /models, /datasets, /runs, /monitor, /vision.
# Leave BLANK by default => fail-closed: the gateway still boots (/healthz, /metrics stay up) but
# protected lifecycle routes return 401 until a key is set — UNLESS GATEWAY_ALLOW_OPEN is truthy.
# (Do NOT leave a placeholder here — a literal value becomes a usable key. Run scripts/gen_secrets.)
GATEWAY_API_KEYS=
# Dev escape hatch (005 US2, FR-042). Truthy (1/true/yes) => run OPEN with no key and log a
# prominent warning. Leave empty in any non-throwaway setup. Never combine with BIND_ADDR=0.0.0.0.
GATEWAY_ALLOW_OPEN=

# Observability
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=__CHANGE_ME__           # required secret — no shipped admin/admin

# Inference tracing (006). Per-request MLflow traces of /infer + /infer/stream, reusing the existing
# MLflow server (MLFLOW_TRACKING_URI). Fire-and-forget + fail-open: never blocks or breaks inference.
MLFLOW_TRACING_ENABLED=1                  # 0/false disables tracing entirely (no per-request overhead)
MLFLOW_TRACE_CAPTURE_IO=1                 # 0/false keeps timing/metadata but omits prompt/output bodies
MLFLOW_TRACING_EXPERIMENT=mlops-lite-inference   # experiment traces land in (separate from training runs)
# Fast-fail backstop for the off-path export worker (defaults applied in app/tracing.py if unset):
# MLFLOW_HTTP_REQUEST_MAX_RETRIES=0
# MLFLOW_HTTP_REQUEST_TIMEOUT=5

# Promotion gate (011). The single registry.promote choke-point consults the evaluation gate before
# moving the @serving alias — every promotion is gated (FR-105). Defaults are safe-by-default; all
# operator-settable. (Per-request `override: true` bypasses a block for a deliberate promote.)
EVAL_GATE_MODE=block                      # block (hard-gate a regression) | warn (allow but flag)
EVAL_GATE_TOLERANCE=0.01                  # relative regression tolerance vs the incumbent (1% absorbs noise)
EVAL_GATE_MISSING_METRIC=warn             # candidate/incumbent has no logged metric: warn (bootstrap) | block
# BENCHMARKS_DIR=                         # override the held-out benchmark fixtures root (default: ./benchmarks)

# Model-quality monitoring (013). Logs served predictions (off the request path, fail-open) + (delayed)
# ground-truth labels into the existing MinIO results bucket, computes windowed per-modality quality
# (reusing 011's metric libs), and fires the existing retrain on a baseline breach (OR + cooldown with
# the input-PSI signal). Complements input-PSI drift; the input path is unchanged.
QUALITY_LOGGING_ENABLED=1                  # 0/false disables prediction logging entirely (no overhead)
QUALITY_CAPTURE_IO=1                       # 0/false logs id+version+timestamp but omits input/prediction bodies
QUALITY_WINDOW_N=100                       # sliding window = the last N labeled pairs (count-based)
QUALITY_MIN_PAIRS=20                       # fewer labeled pairs in the window => "insufficient data", no breach
QUALITY_DROP_PCT=0.10                      # breach when the windowed metric drops >X% below the 011 baseline
QUALITY_RETRAIN_COOLDOWN_SEC=3600          # OR+cooldown debounce shared by the PSI + quality retrain triggers

# Data validation + batch inference (014). Validation is hand-rolled (no Great Expectations): the
# training flow hard-gates on required-columns + min-row-count before train_lora; null-rate/range/
# label-balance warn. Batch inference scores a dataset version offline (content-addressed result on
# MinIO) through the serving lease (GPU) or off-lease (tabular). All thresholds are defaults, not pinned.
VALIDATION_MIN_ROWS=10                      # min-row-count hard-gate for training
VALIDATION_MAX_NULL_RATE=0.2               # per-column null-rate warn threshold
VALIDATION_MIN_LABEL_FRACTION=0.05         # label-balance warn: smallest class must be >= this fraction
BATCH_ABORT_THRESHOLD=0.5                  # abort a batch job if > this fraction of rows fail
BATCH_ABORT_MIN_ROWS=5                     # only enforce the abort threshold after this many rows

# Swap-on-demand (017). 008's cooperative refuse-if-held lease gains an operator-confirmed PREEMPTIVE
# swap for *serving* models: a serving request with "preempt": true evicts a resident serving model
# (LLM/vision/ASR) so a different serving modality can load — one model in VRAM, sequential evict->load.
# Default (no "preempt") is byte-for-byte 008 refuse-if-held. A running training/HPO/batch job is NEVER
# preempted (refused). The gateway brokers the swap via an unload-now control call on the holder.
SWAP_DRAIN_TIMEOUT_S=10                     # holder drains in-flight request(s) up to this, then hard-unloads
SWAP_FREE_WAIT_S=30                         # gateway waits up to this for the lease to free after unload-now
SWAP_MAX_RERESOLVE=3                        # re-resolve the holder up to N times if unload-now reports idle (stale)
# SWAP_CONTROL_SECRET=                      # opt-in: if set, unload-now requires this X-Swap-Control secret (gateway forwards it); unset = 008 behavior
